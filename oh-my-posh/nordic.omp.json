{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 2,
  "final_space": true,
  "console_title_template": "{{ .Shell }} @ {{ .Folder }}",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "foreground": "#4C566A",
          "template": "╭─"
        },
        {
          "type": "os",
          "style": "plain",
          "foreground": "#88C0D0",
          "template": "[\uf303 arch]"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#4C566A",
          "template": "─"
        },
        {
          "type": "session",
          "style": "plain",
          "foreground": "#81A1C1",
          "template": "[\uf007 {{ .UserName }}]"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#4C566A",
          "template": "─"
        },
        {
          "type": "path",
          "style": "plain",
          "foreground": "#88C0D0",
          "properties": {
            "style": "full",
            "home_icon": "~"
          },
          "template": "[\uf07b {{ .Path }}]"
        },
        {
          "type": "text",
          "style": "plain",
          "foreground": "#4C566A",
          "template": "─"
        },
        {
          "type": "git",
          "style": "plain",
          "foreground": "#A3BE8C",
          "foreground_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}#EBCB8B{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}#D08770{{ end }}",
            "{{ if gt .Behind 0 }}#BF616A{{ end }}"
          ],
          "properties": {
            "fetch_status": true,
            "branch_icon": "\ue725 "
          },
          "template": "[\ue725 {{ .HEAD }}{{ if .Working.Changed }} \uf044{{ end }}{{ if .Staging.Changed }} \uf046{{ end }}{{ if gt .Ahead 0 }} \u2191{{ .Ahead }}{{ end }}{{ if gt .Behind 0 }} \u2193{{ .Behind }}{{ end }}]"
        },
        {
          "type": "executiontime",
          "style": "plain",
          "foreground": "#B48EAD",
          "properties": {
            "threshold": 500,
            "style": "austin"
          },
          "template": "─[\uf252 {{ .FormattedMs }}]"
        }
      ]
    },
    {
      "type": "rprompt",
      "alignment": "right",
      "segments": [
        {
          "type": "time",
          "style": "plain",
          "foreground": "#4C566A",
          "template": "\uf017 {{ .CurrentDate | date \"15:04\" }}"
        }
      ]
    },
    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "exit",
          "style": "plain",
          "foreground": "#A3BE8C",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#BF616A{{ end }}"
          ],
          "template": "╰{{ if .Root }}─[\uf0e7 root]{{ end }}─{{ if gt .Code 0 }}\u276f{{ else }}\u276f{{ end }} ",
          "properties": {
            "always_enabled": true
          }
        }
      ]
    }
  ]
}
